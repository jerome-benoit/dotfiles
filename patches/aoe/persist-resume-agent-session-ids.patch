+impl std::fmt::Debug for CaptureGate {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        let state = self.inner.lock().ok();
+        f.debug_struct("CaptureGate")
+            .field("done", &state.as_ref().map(|s| s.done))
+            .finish()
+    }
+}
