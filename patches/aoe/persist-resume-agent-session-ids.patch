new file mode 100644
index 00000000..b21b95c4
--- /dev/null
+++ b/perl-lib/IPC/Cmd.pm
@@ -0,0 +1,23 @@
+package IPC::Cmd;
+use strict;
+use warnings;
+our $VERSION = '1.02';
+
+sub can_run {
+    my ($cmd) = @_;
+    return undef unless defined $cmd;
+    
+    for my $dir (split /:/, $ENV{PATH}) {
+        my $full = "$dir/$cmd";
+        return $full if -x $full;
+    }
+    return undef;
+}
+
+sub run {
+    my ($cmd, @args) = @_;
+    system($cmd, @args);
+    return $? == 0;
+}
+
+1;
