+fn extract_cwd_from_json(parsed: &serde_json::Value, keys: &[&str]) -> Option<String> {
+    keys.iter()
+        .find_map(|key| parsed.get(*key).and_then(|v| v.as_str()))
+        .map(String::from)
+}
