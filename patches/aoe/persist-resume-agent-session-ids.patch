+const ENV_CACHE_TTL: Duration = Duration::from_secs(30);
+
+struct EnvCacheEntry {
+    value: String,
+    fetched_at: Instant,
+}
+
+struct EnvCache {
+    entries: Option<HashMap<(String, String), EnvCacheEntry>>,
+}
+
+static ENV_CACHE: RwLock<EnvCache> = RwLock::new(EnvCache { entries: None });
