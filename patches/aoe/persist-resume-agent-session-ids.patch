From c71af050e82714e5010e3a24a65fa93ddf18fd3d Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?J=C3=A9r=C3=B4me=20Benoit?= <jerome.benoit@sap.com>
Date: Sat, 28 Mar 2026 13:39:49 +0100
Subject: [PATCH 117/117] fix(session): recover poisoned mutex in stop_poller
 instead of silently skipping

---
 src/session/instance.rs | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/src/session/instance.rs b/src/session/instance.rs
index 9bada7a4..26238d20 100644
--- a/src/session/instance.rs
+++ b/src/session/instance.rs
@@ -1000,8 +1000,9 @@ impl Instance {
 
     fn stop_poller(&self) {
         if let Some(ref poller_arc) = self.session_id_poller {
-            if let Ok(mut poller) = poller_arc.lock() {
-                poller.stop();
+            match poller_arc.lock() {
+                Ok(mut poller) => poller.stop(),
+                Err(e) => e.into_inner().stop(),
             }
         }
     }
