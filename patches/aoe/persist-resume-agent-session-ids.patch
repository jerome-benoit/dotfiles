+                return;
+            }
+        };
+
+        let count = ACTIVE_POLLER_COUNT.load(Ordering::SeqCst);
+        if count >= MAX_POLLER_THREADS {
+            tracing::warn!(
+                "Poller thread budget exhausted ({}/{}), skipping poller for {}",
+                count,
+                MAX_POLLER_THREADS,
+                instance_id
