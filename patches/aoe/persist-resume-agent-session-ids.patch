+    struct TmuxSessionGuard {
+        sessions: Vec<String>,
+    }
+
+    impl Drop for TmuxSessionGuard {
+        fn drop(&mut self) {
+            for name in &self.sessions {
+                let _ = std::process::Command::new("tmux")
+                    .args(["kill-session", "-t", name])
+                    .output();
+            }
+        }
+    }
