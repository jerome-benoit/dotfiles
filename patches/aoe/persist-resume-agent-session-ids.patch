+
+        if let Ok(mut cache) = ENV_CACHE.write() {
+            let entries = cache.entries.get_or_insert_with(HashMap::new);
+            entries.insert(
+                (session.to_string(), key.to_string()),
+                EnvCacheEntry {
+                    value: Some("val".to_string()),
+                    fetched_at: Instant::now(),
+                },
