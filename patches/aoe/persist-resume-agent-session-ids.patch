+        );
+        assert!(
+            !results[2].contains("opencode-session-CCC"),
+            "Instance 3 exclusion set must NOT contain its own CCC, got: {:?}",
+            results[2]
+        );
+
+        for i in 0..3 {
+            assert!(
+                !results[i].contains(captured_sessions[i]),
+                "Instance {} exclusion set must not contain its own captured session {}",
+                i + 1,
+                captured_sessions[i]
+            );
+        }
+    }
