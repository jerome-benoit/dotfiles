+                updates.push((inst.id.clone(), session_id));
+                continue;
+            }
+
+            // Completed capture gates (deferred capture agents)
+            if inst.agent_session_id.is_none() {
+                if let Some(session_id) = inst.capture_gate.as_ref().and_then(|g| g.try_take()) {
+                    updates.push((inst.id.clone(), session_id));
+                }
+            }
+        }
+
