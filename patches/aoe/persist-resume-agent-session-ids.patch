+        clear_env_cache();
+        let key = ("cache_test_sess".to_string(), "MY_KEY".to_string());
+
+        if let Ok(mut cache) = ENV_CACHE.write() {
+            let entries = cache.entries.get_or_insert_with(HashMap::new);
+            entries.insert(
