+        let mut interval =
+            AdaptiveInterval::new(Duration::from_secs(2), Duration::from_secs(60), 1.5, 3);
+        assert_eq!(interval.stable_count, 0);
+        interval.record_no_change();
+        assert_eq!(interval.stable_count, 1);
+        interval.record_no_change();
+        assert_eq!(interval.stable_count, 2);
+    }
